# Contentstack credentials (server-side, never exposed to browser)
CONTENTSTACK_API_KEY=your_api_key
CONTENTSTACK_DELIVERY_TOKEN=your_delivery_token
CONTENTSTACK_ENVIRONMENT=preview

# LaunchDarkly client-side ID (safe to expose — this is NOT a server/SDK key)
VITE_LAUNCHDARKLY_CLIENT_ID=your_client_side_id
